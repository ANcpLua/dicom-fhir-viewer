# Backend HTTP listen port (Hono server)
BACKEND_PORT=3000

# Base URL of the Orthanc PACS server (host:port, no trailing slash)
ORTHANC_BASE_URL=http://localhost:8042

# DICOMweb plugin root path inside Orthanc (matches orthanc.json "Root")
ORTHANC_DICOMWEB_ROOT=/dicom-web

# Allowed CORS origins for the browser-facing /api/* routes (comma-separated).
# Wildcard "*" is accepted for local development only.
CORS_ORIGINS=http://localhost:5173

# SQLite file path for the Silver-layer FHIR store. Directory is created on boot.
FHIR_STORE_PATH=./data/fhir.db
